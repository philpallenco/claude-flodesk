# Flodesk API key — Account → Integrations → API in your Flodesk dashboard
FLODESK_API_KEY=your_flodesk_api_key_here

# Slack bot token — needs chat:write scope
# Create at https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# ID of the #ppc-marketing channel (right-click channel → Copy channel ID in Slack)
SLACK_CHANNEL_ID=C0000000000
